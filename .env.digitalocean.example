# DigitalOcean Sydney production deployment.
# Copy to .env on the server and fill in the secrets.

SITE_DOMAIN=rheumai.com
ACME_EMAIL=admin@rheumai.com

POSTGRES_DB=rheum_biologics
POSTGRES_USER=rheum
# Use a long URL-safe password because it is interpolated into DATABASE_URL.
POSTGRES_PASSWORD=replace-with-a-long-random-password

BIOLOGICS_INGEST_ENABLED=true
BIOLOGICS_INGEST_CRON="0 4 1,3,5,7,15 * *"
BIOLOGICS_INGEST_TZ=Australia/Sydney
BIOLOGICS_INGEST_LOOKBACK=3
INGESTION_EMAIL_NOTIFY=true

ANALYTICS_ENABLED=true
# Use a long random value. This is used to hash visitor IP/user-agent data.
ANALYTICS_SALT=replace-with-a-long-random-analytics-salt
# Required for GET /api/analytics/summary.
ANALYTICS_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Feedback issues. Leave GITHUB_TOKEN empty to disable GitHub issue creation.
GITHUB_OWNER=cmcmaster1
GITHUB_REPO=rheum_biologics
GITHUB_TOKEN=

# Optional SMTP email for feedback/ingestion notifications.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=admin@rheumai.com
